{
  "name": "n8n-nodes-ledgermem",
  "version": "0.1.0",
  "description": "n8n community nodes for LedgerMem — long-term memory for AI agents",
  "keywords": ["n8n-community-node-package", "ledgermem", "memory", "ai", "rag"],
  "license": "MIT",
  "homepage": "https://proofly.dev",
  "author": { "name": "LedgerMem", "email": "founders@proofly.dev" },
  "repository": { "type": "git", "url": "git+https://github.com/ledgermem/ledgermem-n8n.git" },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "echo 'lint placeholder'",
    "test": "vitest run"
  },
  "files": ["dist"],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": ["dist/credentials/LedgerMemApi.credentials.js"],
    "nodes": [
      "dist/nodes/LedgerMem/LedgerMem.node.js",
      "dist/nodes/LedgerMemTrigger/LedgerMemTrigger.node.js",
      "dist/nodes/MemoryAugmentedLLM/MemoryAugmentedLLM.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "20.11.0",
    "gulp": "4.0.2",
    "n8n-workflow": "1.62.0",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
